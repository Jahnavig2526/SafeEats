PORT=4000
CLIENT_ORIGIN=*
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="SafeEats <your-email@gmail.com>"
OTP_TTL_MS=600000
ALLOW_DEV_OTP_RESPONSE=true
AUTH_DB_PATH=data/auth.db
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_EMAIL_VERIFY_SECRET=replace-with-strong-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
EMAIL_VERIFY_TOKEN_TTL=15m
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
REQUIRE_OTP_FOR_REGISTER=true
REQUIRE_OTP_FOR_LOGIN=true
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=80
